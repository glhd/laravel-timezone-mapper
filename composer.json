{
	"name": "glhd/laravel-timezone-mapper",
	"description": "Timezone mapper for Laravel",
	"keywords": [
		"laravel",
		"timezone"
	],
	"authors": [
		{
			"name": "Chris Morrell",
			"homepage": "http://www.cmorrell.com"
		}
	],
	"license": "MIT",
	"require": {
		"php": ">=8.1",
		"illuminate/support": "*"
	},
	"require-dev": {
		"friendsofphp/php-cs-fixer": "^3.93",
		"orchestra/testbench": "^6.24|^7.10|^8.33|^9.17|^10.11|^11.0|12.x-dev",
		"phpunit/phpunit": "^12.5|^13.0",
		"mockery/mockery": "^1.6"
	},
	"autoload": {
		"psr-4": {
			"Galahad\\TimezoneMapper\\": "src/"
		}
	},
	"autoload-dev": {
		"classmap": [
			"tests/TestCase.php"
		],
		"psr-4": {
			"Galahad\\TimezoneMapper\\Tests\\": "tests/"
		}
	},
	"minimum-stability": "stable",
	"extra": {
		"laravel": {
			"providers": [
				"Galahad\\TimezoneMapper\\TimezoneMapperProvider"
			],
			"aliases": {
				"TimezoneMapper": "Galahad\\TimezoneMapper\\Facades\\TimezoneMapper"
			}
		}
	}
}
